-- servises
local rs = game:GetService("ReplicatedStorage")
local tw = game:GetService("TweenService")
local plrs = game:GetService("Players")
local runs = game:GetService("RunService")

-- constants
local maxRangeX = 30
local maxRangeY = 30

-- modules
local hitBoxModule = require(rs:FindFirstChild("RaycastHitboxV4"))

local Bird = {}
Bird.__index = Bird

function Bird.new(birdModel:Model,_speed:number, _hp:number, _loveNeeded:number , _damage:number , _cd:number, _attackLength:number , name:string , image:string , sound , birdType:string , birdRarity:string, hitbox:Part)
	local self = setmetatable({},Bird)
	
	-- status
	self._stats = {
		hp = _hp,
		speed = _speed,
		damage = _damage,
		cd = _cd,
		attackLength = _attackLength,
		loveNeeded = _loveNeeded
	}
	
	self._isAttacking = false
	
	self._currentLove = {}
	self._isTame = false 
	
	-- info
	self._name = name
	self._image = image
	self._sound = sound
	
	self._type = birdType
	self._rarity = birdRarity
	
	-- bird
	self._bird = birdModel
	
	-- tween
	self._tweenInfo = TweenInfo.new(_speed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0)
	
	-- animation
	local animation = birdModel:FindFirstChild("animations")
	
	self._track = {}
	
	if animation then
		local animator = birdModel:FindFirstChild("Humanoid"):FindFirstChild("Animator")
		
		if animator then
			
			for _, ani in animation do
				
				local track = animator:LoadAnimation(ani)
				
				self._track[ani.Name] = track
			end
			
		end
		
	end
	
	-- hitbox
	local Hitbox = hitBoxModule.new(hitbox)

	Hitbox.OnHit:Connect(function(hit, humanoid)
		print(hit.Name)
		humanoid:TakeDamage(_damage)
	end)
	
	self._hitbox = Hitbox
	
	return self
end

function Bird:attack()
	if self._isAttacking == true then return end
	
	-- start attacking
	self._isAttacking = true
	self._hitbox:HitStart()
	
	-- play animation
	if self._track["attack"] then
		self._track["attack"]:Play()
	end
	
	-- stop attacking
	task.delay(self._stats["attackLength"], function()
		self._hitbox:HitStop()
		self._isAttacking = false
	end)
	
end

function Bird:Ai()
	print("AI Started for: " .. self._name)

	task.spawn(function()
		while self._bird and self._bird.Parent do
			if self._track["idle"] then self._track["idle"]:Play() end
			task.wait(math.random(2, 5)) 

			local target = nil
			for _, player in ipairs(plrs:GetPlayers()) do
				local char = player.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					local dist = (char.HumanoidRootPart.Position - self._bird:GetPivot().Position).Magnitude
					if dist <= 5 then
						target = char
						break
					end
				end
			end

			if target then
				-- Attack logic
				self:attack()
				task.wait(self._stats["cd"] or 1)
			else
				local currentPos = self._bird:GetPivot().Position
				local offsetX = math.random(-maxRangeX, maxRangeX)
				local offsetZ = math.random(-maxRangeY, maxRangeY)
				local targetPos = currentPos + Vector3.new(offsetX, 0, offsetZ)

				local lookCFrame = CFrame.lookAt(currentPos, targetPos)

				if self._track["walk"] then self._track["walk"]:Play() end

				local moveTween = tw:Create(self._bird.PrimaryPart, self._tweenInfo, {
					CFrame = CFrame.lookAt(targetPos, targetPos + (targetPos - currentPos))
				})

				moveTween:Play()
				moveTween.Completed:Wait()

				if self._track["walk"] then self._track["walk"]:Stop() end
			end

			task.wait(0.1)
		end
	end)
end

function Bird:Love(player:Player)
	if self._isTame == true then return end
	
	-- play animation
	if self._track then
		self._track["love"]:Play()
	end
	
	for _, player in self._currentLove do
		if self._currentLove[player] >= self._stats["loveNeeded"] then return end
	end
	
	if self._currentLove[player] ~= nil then
		self._currentLove[player] += 1
	else
		self._currentLove[player] = 1
	end
	
end

function Bird:taming(player:Player)
	if self._owner ~= nil then return end
	
	-- play animation
	if self._track then
		self._track["taming"]:Play()
	end
	
	self._currentLove = 0
	self._isTame = true
	
	self._owner = player.UserId
	self._stats["loveNeeded"] = -1
end 

function Bird:Destory()
	if self._hitBox then
		self._hitBox:HitStop()
		self._hitBox:Destroy()
		self._hitBox = nil
	end

	if self._track then
		for _, track in pairs(self._track) do
			track:Stop()
			track:Destroy()
		end
		self._track = nil
	end

	if self._bird then
		self._bird:Destroy()
		self._bird = nil
	end
	
	if self._hartBeat then
		self._hartBeat:Disconnect()
		self._hartBeat = nil
	end
	
	self._stats = nil
	self._currentLove = nil

	setmetatable(self, nil)
	table.clear(self)
end

return Bird
