-- servises
local rs = game:GetService("ReplicatedStorage")
local tw = game:GetService("TweenService")
local plrs = game:GetService("Players")
local runs = game:GetService("RunService")

-- constants
local maxRangeX = 30
local maxRangeY = 30

-- modules
local hitBoxModule = require(rs:FindFirstChild("RaycastHitboxV4"))

local Bird = {}
Bird.__index = Bird

function Bird.new(birdModel:Model,_speed:number, _hp:number, _loveNeeded:number , _damage:number , _cd:number, _attackLength:number , name:string , image:string , sound , birdType:string , birdRarity:string, hitbox:Part)
	local self = setmetatable({},Bird)
	
	-- status
	self._stats = {
		"hp" == _hp,
		"speed" == _speed,
		"damage" == _damage,
		"cd" == _cd,
		"speed" == _speed,
		"attackLength" == _attackLength,
		"loveNeeded" == _loveNeeded
	}
	
	self._isAttacking = false
	
	self._currentLove = {}
	self._isTame = false 
	
	-- info
	self._name = name
	self._image = image
	self._sound = sound
	
	self._type = birdType
	self._rarity = birdRarity
	
	-- bird
	self._bird = birdModel
	
	-- tween
	self._tweenInfo = TweenInfo.new(self._stats["speed"], Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0)
	
	-- animation
	local animation = birdModel:FindFirstChild("animations")
	
	self._track = {}
	
	if animation then
		local animator = birdModel:FindFirstChild("Humanoid"):FindFirstChild("Animator")
		
		if animator then
			
			for _, ani in animation do
				
				local track = animator:LoadAnimation(ani)
				
				self._track[ani.Name] = track
			end
			
		end
		
	end
	
	-- hitbox
	self._hitBox = hitBoxModule.new(hitbox)
	hitbox.OnHit:Connect(function(hit, humanoid)
		print(hit.Name)
		humanoid:TakeDamage(self._stats["damage"])
	end)

	return self
end

function Bird:attack()
	if self._isAttacking == true then return end
	
	-- start attacking
	self._isAttacking = true
	self._hitbox:HitStart()
	
	-- play animation
	if self._track then
		self._track["attack"]:Play()
	end
	
	-- stop attacking
	task.delay(self.self._stats["attackLength"], function()
		self._hitbox:HitStop()
		self._isAttacking = false
	end)
	
end

function Bird:Ai()
	local walking = false
	
	self._hartBeat = runs.Heartbeat:Connect(function()
		if walking then return end
		
		walking = true
		
		local poseX = math.random(-maxRangeX, maxRangeX)
		local poseY = math.random(-maxRangeY, maxRangeY)

		local randomPos = Vector3.new(poseX, poseY, 0)

		if not self._stats["speed"] then return end
		if not self._track["walk"] then return end

		local tween = tw:Create(self._bird, self._tweenInfo, {Position = self._bird.Position + randomPos})
		tween:Play()

		self._track["walk"]:Play()

		tween.Completed:Connect(function()
			self._track["walk"]:Stop()

			for _, player in plrs:GetChildren() do
				if player.Character == nil then continue end

				if player.Character:FindFirstChild("HumanoidRootPart") == nil then continue end

				local distance = (player.Character.HumanoidRootPart.Position - self._bird.Position).Magnitude

				if distance <= 10 then
					Bird:attack()
					task.wait(self._stats["attackLength"])
				end

				self._track["idle"]:Play()
			end
		end)
		
		walking = false
	end)
end

function Bird:Love(player:Player)
	if self._isTame == true then return end
	
	-- play animation
	if self._track then
		self._track["love"]:Play()
	end
	
	for _, player in self._currentLove do
		if self._currentLove[player] >= self._stats["loveNeeded"] then return end
	end
	
	if self._currentLove[player] ~= nil then
		self._currentLove[player] += 1
	else
		self._currentLove[player] = 1
	end
	
end

function Bird:taming(player:Player)
	if self._owner ~= nil then return end
	
	-- play animation
	if self._track then
		self._track["taming"]:Play()
	end
	
	self._currentLove = 0
	self._isTame = true
	
	self._owner = player.UserId
	self._stats["loveNeeded"] = -1
end 

function Bird:Destory()
	if self._hitBox then
		self._hitBox:HitStop()
		self._hitBox:Destroy()
		self._hitBox = nil
	end

	if self._track then
		for _, track in pairs(self._track) do
			track:Stop()
			track:Destroy()
		end
		self._track = nil
	end

	if self._bird then
		self._bird:Destroy()
		self._bird = nil
	end
	
	if self._hartBeat then
		self._hartBeat:Disconnect()
		self._hartBeat = nil
	end
	
	self._stats = nil
	self._currentLove = nil

	setmetatable(self, nil)
	table.clear(self)
end

return Bird
