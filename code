local players = {}

-- Services
local rs = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")

-- Settings 
local run: boolean = true 
local customWalkSound: boolean = true 
local notCustomWalkSound: number = 0.5 -- from 1 to 0
local walkSpeed: number = 10
local runSpeed: number = 20

-- assets
local animationFolder = rs:WaitForChild("Animations")
local walkAnimationFolder = animationFolder:FindFirstChild("walkAnimationFolder")
local runAnimationFolder = animationFolder:FindFirstChild("runAnimationFolder")

-- helper command

local function getMaterial(humanoid: Humanoid)
	local floormat = humanoid.FloorMaterial
	if not floormat or floormat == Enum.Material.Air then return "Plastic" end

	local matstring = string.split(tostring(floormat), "Enum.Material.")[2]
	return matstring or "Plastic"
end

local function stopAllAnimations(animations)
	if not animations then return end
	for _, track in pairs(animations) do
		if typeof(track) == "Instance" and track:IsA("AnimationTrack") then
			track:Stop(0.1)
		end
	end
end

local function loadAnimation(folder, humanoid, root)
	if not folder then return nil end
	local animations = folder:GetChildren()
	if #animations == 0 then return nil end

	local loadedTable = {}

	for _, animObject in pairs(animations) do
		if animObject:IsA("Animation") then
			local track = humanoid:LoadAnimation(animObject)
			loadedTable[animObject.Name] = track

			if not customWalkSound then continue end
			
			-- Sound Triggering Logic
			track:GetMarkerReachedSignal("Sound"):Connect(function()
				local material = getMaterial(humanoid)
				local soundFolder = rs:FindFirstChild("sounds") and rs.sounds:FindFirstChild("footStep")
				if not soundFolder then return end

				local materialFolder = soundFolder:FindFirstChild(material) or soundFolder:GetChildren()[1]
				if not materialFolder then return end

				local sounds = materialFolder:GetChildren()
				if #sounds > 0 then
					local randomSound = sounds[math.random(1, #sounds)]
					local sound = randomSound:Clone()
					sound.Parent = root
					sound:Play()
					Debris:AddItem(sound, sound.TimeLength + 0.1)
				end
			end)
		end
	end

	return loadedTable
end

-- Core System 

function players.newPlayer(_char: Model)
	if not _char then return end

	local player = {}

	-- player Var
	local char = _char
	local root = char:WaitForChild("HumanoidRootPart")
	local hum = char:WaitForChild("Humanoid")

	-- status Var
	local currentDirection = nil
	local running = false
	local internalChange = false 

	-- Character Initialization
	local animateScript = char:FindFirstChild("Animate")
	if animateScript then animateScript.Disabled = true end

	root.Running.Volume = customWalkSound and 0 or notCustomWalkSound

	-- Loading
	local walkAnimations = loadAnimation(walkAnimationFolder, hum, root)
	local runAnimations = run and loadAnimation(runAnimationFolder, hum, root) or nil

	if walkAnimations and walkAnimations["Idle"] then
		walkAnimations["Idle"]:Play()
	end

	-- Methods

	function player:toggleRunning()
		if not run or not runAnimations then return end

		running = not running
		hum.WalkSpeed = running and runSpeed or walkSpeed

		stopAllAnimations(runAnimations)
		stopAllAnimations(walkAnimations)

		local transition = running and walkAnimations["toRun"] or runAnimations["toWalk"]

		if transition and currentDirection ~= nil then
			internalChange = true
			transition:Play()

			local connection
			connection = transition.Ended:Connect(function()
				internalChange = false
				connection:Disconnect()
			end)
		else
			if walkAnimations["Idle"] then
				walkAnimations["Idle"]:Play()
			end
		end

		currentDirection = nil 
	end

	function player:update()
		if not root or not hum or hum.Health <= 0 then return end
		if internalChange then return end

		local moveDir = hum.MoveDirection
		local velocity = root.CFrame:VectorToObjectSpace(moveDir)

		local newDirection = nil
		if velocity.X < -0.5 then newDirection = "Left"
		elseif velocity.X > 0.5 then newDirection = "Right"
		elseif velocity.Z < -0.5 then newDirection = "Backward"
		elseif velocity.Z > 0.5 then newDirection = "Forward"
		end

		local activeAnims = (running and runAnimations) or walkAnimations
		if not activeAnims then return end

		if newDirection ~= currentDirection then
			stopAllAnimations(activeAnims)

			if newDirection ~= nil then
				if activeAnims[newDirection] then
					activeAnims[newDirection]:Play()
				end
			else
				local endAnim = currentDirection and activeAnims[currentDirection .. "End"]
				if endAnim then endAnim:Play() end

				if activeAnims["Idle"] then
					activeAnims["Idle"]:Play()
				end
			end
			currentDirection = newDirection
		end
	end

	function player:clean()
		-- Stop and destroy all tracks
		local allPacks = {walkAnimations, runAnimations}
		for _, pack in ipairs(allPacks) do
			if pack then
				for _, track in pairs(pack) do
					track:Stop(0)
					track:Destroy()
				end
				table.clear(pack)
			end
		end

		-- Reference Cleanup
		walkAnimations = nil
		runAnimations = nil
		char = nil
		root = nil
		hum = nil

	end

	return player
end

return players
