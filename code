local PerkManager = {}

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

local PerkDataStore = DataStoreService:GetDataStore("PlayerPerks_v4_Final")
local Remote = Instance.new("RemoteEvent")
Remote.Name = "PerkSystemRemote"
Remote.Parent = ReplicatedStorage

local SessionState = {}
local GlobalSettings = {
	MaxSlots = 2,
	DefaultCooldown = 5,
	SaveInterval = 300,
	LoggingEnabled = true
}

type PerkProfile = {
	Name: string,
	Cooldown: number,
	Duration: number,
	Execute: (Player, Character: Model) -> (),
	Cleanup: (Player, Character: Model) -> ()?,
	Passive: ((Player, Character: Model, DeltaTime: number) -> ())?
}

type InternalState = {
	Timers: { [string]: number },
	ActiveEffects: { [string]: boolean },
	StartTime: { [string]: number },
	LastUpdate: number
}

local function Log(message: string)
	if GlobalSettings.LoggingEnabled then
		print(string.format("[PerkManager @ %s]: %s", os.date("%X"), message))
	end
end

local function SecureCall(func)
	local success, result = pcall(func)
	local retries = 0
	while not success and retries < 3 do
		task.wait(1)
		success, result = pcall(func)
		retries += 1
	end
	return success, result
end

local function GetPerkModule(name: string): PerkProfile?
	local folder = ReplicatedStorage:FindFirstChild("PerkModules")
	if not folder then 
		warn("PerkModules folder missing in ReplicatedStorage")
		return nil 
	end
	
	local module = folder:FindFirstChild(name)
	if module and module:IsA("ModuleScript") then
		local success, perk = pcall(require, module)
		if success then return perk end
	end
	return nil
end

local function Initialize(player: Player)
	local dataFolder = Instance.new("Configuration")
	dataFolder.Name = "PerkData"
	
	for i = 1, GlobalSettings.MaxSlots do
		local slot = Instance.new("StringValue")
		slot.Name = "Slot" .. i
		slot.Value = ""
		slot.Parent = dataFolder
	end
	
	dataFolder.Parent = player
	
	SessionState[player.UserId] = {
		Timers = {Slot1 = 0, Slot2 = 0},
		ActiveEffects = {Slot1 = false, Slot2 = false},
		StartTime = {Slot1 = 0, Slot2 = 0},
		LastUpdate = os.clock()
	}
	
	local success, savedData = SecureCall(function()
		return PerkDataStore:GetAsync(tostring(player.UserId))
	end)
	
	if success and savedData then
		dataFolder.Slot1.Value = savedData.Slot1 or ""
		dataFolder.Slot2.Value = savedData.Slot2 or ""
		Log("Successfully initialized data for " .. player.Name)
	else
		Log("Created new profile for " .. player.Name)
	end
end

local function Save(player: Player)
	local data = player:FindFirstChild("PerkData")
	if not data then return end
	
	local payload = {
		Slot1 = data.Slot1.Value,
		Slot2 = data.Slot2.Value,
		LastSaved = os.time(),
		SessionID = HttpService:GenerateGUID(false)
	}
	
	local success, err = SecureCall(function()
		PerkDataStore:SetAsync(tostring(player.UserId), payload)
	end)
	
	if not success then
		warn("Failed to save data for " .. player.Name .. ": " .. tostring(err))
	end
end

function PerkManager.SetPerk(player: Player, slot: number, name: string)
	if slot < 1 or slot > GlobalSettings.MaxSlots then return end
	
	local data = player:FindFirstChild("PerkData")
	if not data then return end
	
	local target = data:FindFirstChild("Slot" .. slot)
	if target then
		target.Value = name
		Log(player.Name .. " equipped " .. name .. " to Slot " .. slot)
	end
end

function PerkManager.Activate(player: Player, key: Enum.KeyCode)
	local char = player.Character
	if not char or char:FindFirstChildOfClass("Humanoid").Health <= 0 then return end
	
	local state = SessionState[player.UserId]
	if not state then return end
	
	local slotName = (key == Enum.KeyCode.E) and "Slot1" or "Slot2"
	local currentTime = os.clock()
	
	if currentTime < state.Timers[slotName] then 
		Log(player.Name .. " activation blocked: Cooldown active")
		return 
	end
	
	local perkName = player.PerkData[slotName].Value
	if perkName == "" then return end
	
	local perk = GetPerkModule(perkName)
	if not perk then return end
	
	state.Timers[slotName] = currentTime + perk.Cooldown
	state.ActiveEffects[slotName] = true
	state.StartTime[slotName] = currentTime
	
	Remote:FireClient(player, "UpdateUI", {
		Slot = slotName,
		CD = perk.Cooldown,
		Name = perk.Name,
		Duration = perk.Duration
	})
	
	task.spawn(function()
		local success, err = pcall(function()
			perk.Execute(player, char)
		end)
		
		if not success then
			warn("Execution Error in Perk " .. perkName .. ": " .. err)
		end
		
		if perk.Duration > 0 then
			task.wait(perk.Duration)
			state.ActiveEffects[slotName] = false
			
			if perk.Cleanup then
				pcall(perk.Cleanup, player, char)
			end
		else
			state.ActiveEffects[slotName] = false
		end
	end)
end

function PerkManager.ForceReset(player: Player)
	local state = SessionState[player.UserId]
	if not state then return end
	
	for slot, _ in pairs(state.Timers) do
		state.Timers[slot] = 0
		state.ActiveEffects[slot] = false
	end
	
	Remote:FireClient(player, "ResetUI")
	Log("Cooldowns forced reset for " .. player.Name)
end

function PerkManager.GetRemainingCooldown(player: Player, slot: string): number
	local state = SessionState[player.UserId]
	if not state then return 0 end
	
	local remaining = state.Timers[slot] - os.clock()
	return math.max(0, remaining)
end

function PerkManager.SyncState(player: Player)
	local state = SessionState[player.UserId]
	if not state then return end
	
	local data = {}
	for slot, time in pairs(state.Timers) do
		data[slot] = math.max(0, time - os.clock())
	end
	
	Remote:FireClient(player, "Sync", data)
end

Players.PlayerAdded:Connect(Initialize)
Players.PlayerRemoving:Connect(function(player)
	Save(player)
	SessionState[player.UserId] = nil
end)

RunService.Heartbeat:Connect(function(dt)
	for _, player in ipairs(Players:GetPlayers()) do
		local state = SessionState[player.UserId]
		local char = player.Character
		if not state or not char then continue end
		
		local data = player:FindFirstChild("PerkData")
		if not data then continue end
		
		for i = 1, GlobalSettings.MaxSlots do
			local slotName = "Slot" .. i
			if state.ActiveEffects[slotName] then
				local perkName = data[slotName].Value
				local perk = GetPerkModule(perkName)
				
				if perk and perk.Passive then
					pcall(perk.Passive, player, char, dt)
				end
			end
		end
	end
end)

game:BindToClose(function()
	Log("Server shutting down, saving all player data...")
	for _, player in ipairs(Players:GetPlayers()) do
		Save(player)
	end
end)

return PerkManager
