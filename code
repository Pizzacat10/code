local players = {}

local currentDirection = nil

-- Service
local rs = game:GetService("ReplicatedStorage")

--global var
local change = false

-- helper functions
local function getMaterial(hum)
	local floormat = hum.FloorMaterial
	if not floormat then floormat = 'Air' end
	
	local matstring = string.split(tostring(floormat),'Enum.Material.')[2]
	local material = matstring
	return material
	
end

local function loadAnimation(folder,humanoid,root)
	local animations = folder:GetChildren()
	if #animations == 0 then return end
	
	local loadedTable  = {}
	
	for _, animObject in pairs(animations) do
		local track = humanoid:LoadAnimation(animObject)
		loadedTable [animObject.Name] = track 
		
		track:GetMarkerReachedSignal("Sound"):Connect(function()
			local material = getMaterial(humanoid)
			local soundFolder = rs.sounds.footStep
						
			local materialFolder = soundFolder:FindFirstChild(material)
			
			if not materialFolder then
				materialFolder = soundFolder:GetChildren()[1] 
			end
			
			print(materialFolder,material)
			
			local sounds = materialFolder:GetChildren()
			
			if (#sounds > 0) then
				local randomSound = sounds[math.random(1, #sounds)]
				
				local sound = randomSound:Clone()
				sound.Parent = root
				sound:Play()
				game.Debris:AddItem(sound,sound.TimeLength + 0.1)
				
			end
		end)
	end
	
	return loadedTable
	
end

local function stopAllAnimation(animations)
	if not animations then return end
	
	for _, animation in pairs(animations) do
		animation:Stop()
		
	end
end

local function playAnimationWithMovement(velocity, animations)
	if change then return end
	local newDirection = nil
	
	if velocity.X < -0.5 then
		newDirection = "Left"
		
	elseif velocity.X > 0.5 then
		newDirection = "Right"
		
	elseif velocity.Z > 0.5 then
		newDirection = "Forward"
		
	elseif velocity.Z < -0.5 then
		newDirection = "Backward"
		
	end

	if newDirection ~= currentDirection then
		stopAllAnimation(animations)

		if newDirection ~= nil then
			
			if animations[newDirection] then
				animations[newDirection]:Play()
				
			end
			
		else
			
			if currentDirection == "Left" and animations.LeftEnd then animations.LeftEnd:Play()
			elseif currentDirection == "Right" and animations.RightEnd then animations.RightEnd:Play()
			elseif currentDirection == "Backward" and animations.BackEnd then animations.BackEnd:Play()
			elseif currentDirection == "Forward" and animations.ForwardEnd then animations.ForwardEnd:Play()
			end

			if animations["Idle"] then
				animations["Idle"]:Play()
				
			end
			
		end

		currentDirection = newDirection
		
	end
end

function players.newPlayer(_char)
	if not _char then return end
	
	local player = {}
	
	-- player vars
	local char = _char
	local root = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChild("Humanoid")
	
	char.Animate.Disabled = true
	char.HumanoidRootPart.Running.Volume = 0
	
	--vars
	local running = false
	local velocity = root.CFrame:VectorToObjectSpace(hum.MoveDirection)
		
	-- animations
	local animationFolder = rs:WaitForChild("Animations")
	local walkAnimationFolder = animationFolder:FindFirstChild("walkAnimationFolder")
	local runAnimationFolder = animationFolder:FindFirstChild("runAnimationFolder")
	
	local walkAnimations = loadAnimation(walkAnimationFolder,hum,root)
	local runAnimation = loadAnimation(runAnimationFolder,hum,root)
	

	if walkAnimations["Idle"] then
		walkAnimations["Idle"]:Play()
		
	end
	
	-- function
	function player.Running()
		running = not running
		
		hum.WalkSpeed = running and 20 or 10
		
		stopAllAnimation(runAnimation)
		stopAllAnimation(walkAnimations)

		local transition = running and walkAnimations["toRun"] or runAnimation["toWalk"]
		
		if transition and currentDirection ~= nil then
			change = true
			transition:Play()
			
			transition.Ended:Connect(function()
				change = false 
				
			end)
			
		else
			
			if walkAnimations["Idle"] then
				walkAnimations["Idle"]:Play()
				
			end
		end
		
		currentDirection = nil 
		
	end

	
	function player.update()
		
		velocity = root.CFrame:VectorToObjectSpace(hum.MoveDirection)
		
		if not running then
			playAnimationWithMovement(velocity,walkAnimations)
			
		else
			playAnimationWithMovement(velocity,runAnimation)

		end
		
	end
	
	return player
	
end

return players
